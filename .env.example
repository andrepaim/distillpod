# Podcast Index API (https://podcastindex.org/developer)
PODCAST_INDEX_API_KEY=your_key_here
PODCAST_INDEX_SECRET=your_secret_here

# Claude CLI — path to binary (optional, falls back to PATH)
# Requires: `claude` CLI installed and authenticated via `claude login`
CLAUDE_BIN=claude

# Storage paths
MEDIA_DIR=/path/to/distillpod/media
DB_PATH=/path/to/distillpod/distillpod.db
REPORTS_DIR=/path/to/distillpod/reports

# Public-facing domain (used for CORS, OAuth redirect, report URLs)
PUBLIC_URL=https://your-domain.example.com

# Server
FRONTEND_ORIGIN=http://localhost:5173

# Transcription (faster-whisper)
WHISPER_MODEL=base             # base / small / medium / large-v3
WHISPER_DEVICE=cpu             # cpu / cuda

# Google OAuth — required for login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAILS=yourname@gmail.com        # comma-separated; only these can log in
SESSION_SECRET=change-this-to-a-random-32-char-string

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Test mode — set true ONLY when running E2E tests locally, NEVER in prod
TEST_MODE=false
