PODCAST_INDEX_API_KEY=your_key_here
PODCAST_INDEX_SECRET=your_secret_here
# Snip summaries use Claude CLI (claude --print) — no API key needed
# Requires: `claude` CLI installed and authenticated via `claude login`
MEDIA_DIR=/root/earshot/media
DB_PATH=/root/earshot/earshot.db
WHISPER_MODEL=base             # base / small / medium / large-v3
FRONTEND_ORIGIN=http://localhost:5173
